n    \"Cross-platform shopping app with real-time inventory and payments.\",\n    \"We built a full-featured e-commerce mobile application for iOS and Android using a modern cross-platform stack. The app includes real-time inventory sync, secure payment integration, and a smooth native experience.\",\n    \"/images/placeholders/case-1.jpg\",\n    \"E-Commerce app on phone and tablet\",\n    \"React Native\",\n    \"Node.js\",\n    \"Stripe\",\n    [\n      \"3a\",\n      \"3b\",\n      \"3c\"\n    ],\n    \"https://example.com\",\n    \"https://demo.example.com\",\n    \"2024-06-15T00:00:00.000Z\",\n    \"2024-05-01T00:00:00.000Z\",\n    {\n      \"id\": \"33\",\n      \"slug\": \"34\",\n      \"title\": \"35\",\n      \"summary\": \"36\",\n      \"description\": \"37\",\n      \"image\": \"38\",\n      \"imageAlt\": \"39\",\n      \"tags\": \"3d\",\n      \"linkUrl\": \"3e\",\n      \"demoUrl\": \"3f\",\n      \"featured\": \"20\",\n      \"publishedAt\": \"3g\",\n      \"createdAt\": \"3h\",\n      \"updatedAt\": \"3g\"\n    },\n    2,\n    \"healthcare-dashboard\",\n    \"Healthcare Analytics Dashboard\",\n    \"Real-time dashboards for hospital operations and patient metrics.\",\n    \"A secure, HIPAA-aware web dashboard for healthcare providers. Features real-time analytics, role-based access, and export to PDF/Excel.\",\n    \"/images/placeholders/case-2.jpg\",\n    \"Dashboard with charts and metrics\",\n    \"Vue.js\",\n    \"Laravel\",\n    \"Charts.js\",\n    [\n      \"3q\",\n      \"3r\",\n      \"3s\"\n    ],\n    \"2024-08-20T00:00:00.000Z\",\n    \"2024-07-01T00:00:00.000Z\",\n    {\n      \"id\": \"3j\",\n      \"slug\": \"3k\",\n      \"title\": \"3l\",\n      \"summary\": \"3m\",\n      \"description\": \"3n\",\n      \"image\": \"3o\",\n      \"imageAlt\": \"3p\",\n      \"tags\": \"3t\",\n      \"linkUrl\": \"3e\",\n      \"featured\": \"20\",\n      \"publishedAt\": \"3u\",\n      \"createdAt\": \"3v\",\n      \"updatedAt\": \"3u\"\n    },\n    5,\n    \"fitness-tracking-app\",\n    \"Fitness & Wellness App\",\n    \"Native iOS and Android app for workouts and progress tracking.\",\n    \"Native mobile apps for fitness tracking, workout plans, and progress analytics. Includes wearables sync and social features.\",\n    \"/images/placeholders/case-5.jpg\",\n    \"Fitness app workout screen\",\n    \"Swift\",\n    \"Kotlin\",\n    \"Firebase\",\n    [\n      \"44\",\n      \"45\",\n      \"46\"\n    ],\n    \"2024-11-05T00:00:00.000Z\",\n    \"2024-10-01T00:00:00.000Z\",\n    {\n      \"id\": \"3x\",\n      \"slug\": \"3y\",\n      \"title\": \"3z\",\n      \"summary\": \"40\",\n      \"description\": \"41\",\n      \"image\": \"42\",\n      \"imageAlt\": \"43\",\n      \"tags\": \"47\",\n      \"linkUrl\": \"3e\",\n      \"featured\": \"20\",\n      \"publishedAt\": \"48\",\n      \"createdAt\": \"49\",\n      \"updatedAt\": \"48\"\n    },\n    [\n      \"3i\",\n      \"3w\",\n      \"4a\"\n    ],\n    \"They delivered our mobile app on time and the quality exceeded expectations. The team understood our vision from day one.\",\n    \"Sarah Chen\",\n    \"CEO, TechStart\",\n    \"\",\n    {\n      \"id\": \"33\",\n      \"quote\": \"4c\",\n      \"authorName\": \"4d\",\n      \"authorRole\": \"4e\",\n      \"authorAvatar\": \"4f\",\n      \"projectTitle\": \"35\",\n      \"rating\": \"3x\",\n      \"approved\": \"20\"\n    },\n    \"Professional, responsive, and technically excellent. Our dashboard is now the backbone of our operations.\",\n    \"James Wilson\",\n    \"CTO, HealthCare Plus\",\n    {\n      \"id\": \"3j\",\n      \"quote\": \"4h\",\n      \"authorName\": \"4i\",\n      \"authorRole\": \"4j\",\n      \"authorAvatar\": \"4f\",\n      \"projectTitle\": \"3l\",\n      \"rating\": \"3x\",\n      \"approved\": \"20\"\n    },\n    3,\n    \"The API and documentation they built allowed our partners to integrate in days, not weeks. Highly recommend.\",\n    \"Maria Garcia\",\n    \"Head of Product, FinanceFlow\",\n    \"Fintech Banking API\",\n    {\n      \"id\": \"4l\",\n      \"quote\": \"4m\",\n      \"authorName\": \"4n\",\n      \"authorRole\": \"4o\",\n      \"authorAvatar\": \"4f\",\n      \"projectTitle\": \"4p\",\n      \"rating\": \"3x\",\n      \"approved\": \"20\"\n    },\n    4,\n    \"From concept to launch, the process was smooth. They brought both design and engineering expertise.\",\n    \"David Kim\",\n    \"Founder, TravelHub\",\n    \"Travel Booking Platform\",\n    {\n      \"id\": \"4r\",\n      \"quote\": \"4s\",\n      \"authorName\": \"4t\",\n      \"authorRole\": \"4u\",\n      \"authorAvatar\": \"4f\",\n      \"projectTitle\": \"4v\",\n      \"rating\": \"3x\",\n      \"approved\": \"20\"\n    },\n    \"Native performance and a great UX. Our users love the fitness app they built for us.\",\n    \"Emma Brown\",\n    \"Product Manager, FitLife\",\n    {\n      \"id\": \"3x\",\n      \"quote\": \"4x\",\n      \"authorName\": \"4y\",\n      \"authorRole\": \"4z\",\n      \"authorAvatar\": \"4f\",\n      \"projectTitle\": \"3z\",\n      \"rating\": \"3x\",\n      \"approved\": \"20\"\n    },\n    [\n      \"4g\",\n      \"4k\",\n      \"4q\",\n      \"4w\",\n      \"50\"\n    ],\n    \"web\",\n    \"Web Development\",\n    \"Fast, scalable web applications\",\n    \"We build modern web applications with React, Vue, or vanilla stacks. From SPAs to SSR and static sites, we focus on performance, SEO, and maintainability.\",\n    \"Discovery & requirements\",\n    \"Design & prototyping\",\n    \"Development & testing\",\n    \"Deploy & maintain\",\n    [\n      \"56\",\n      \"57\",\n      \"58\",\n      \"59\"\n    ],\n    \"Responsive web app\",\n    \"API integration\",\n    \"CMS if needed\",\n    \"Documentation & handoff\",\n    [\n      \"5b\",\n      \"5c\",\n      \"5d\",\n      \"5e\"\n    ],\n    {\n      \"id\": \"52\",\n      \"slug\": \"52\",\n      \"name\": \"53\",\n      \"shortDescription\": \"54\",\n      \"description\": \"55\",\n      \"process\": \"5a\",\n      \"deliverables\": \"5f\",\n      \"icon\": \"52\"\n    },\n    \"android\",\n    \"Android Development\",\n    \"Native and Kotlin-first Android apps\",\n    \"Native Android apps with Kotlin and Jetpack. We follow Material Design and ensure compatibility across devices and OS versions.\",\n    \"UX & architecture\",\n    \"Development in Kotlin\",\n    \"Testing on devices\",\n    \"Play Store release\",\n    [\n      \"5l\",\n      \"5m\",\n      \"5n\",\n      \"5o\"\n    ],\n    \"Native Android app\",\n    \"CI/CD pipeline\",\n    \"Play Store listing\",\n    \"Maintenance plan\",\n    [\n      \"5q\",\n      \"5r\",\n      \"5s\",\n      \"5t\"\n    ],\n    {\n      \"id\": \"5h\",\n      \"slug\": \"5h\",\n      \"name\": \"5i\",\n      \"shortDescription\": \"5j\",\n      \"description\": \"5k\",\n      \"process\": \"5p\",\n      \"deliverables\": \"5u\",\n      \"icon\": \"5h\"\n    },\n    \"ios\",\n    \"iOS Development\",\n    \"Native Swift and SwiftUI apps\",\n    \"Native iOS apps with Swift and SwiftUI. We deliver apps that feel at home on iPhone and iPad and comply with App Store guidelines.\",\n    \"Design & UX\",\n    \"Swift/SwiftUI development\",\n    \"TestFlight & QA\",\n    \"App Store submission\",\n    [\n      \"60\",\n      \"61\",\n      \"62\",\n      \"63\"\n    ],\n    \"Native iOS app\",\n    \"App Store assets\",\n    \"TestFlight setup\",\n    \"Ongoing updates\",\n    [\n      \"65\",\n      \"66\",\n      \"67\",\n      \"68\"\n    ],\n    {\n      \"id\": \"5w\",\n      \"slug\": \"5w\",\n      \"name\": \"5x\",\n      \"shortDescription\": \"5y\",\n      \"description\": \"5z\",\n      \"process\": \"64\",\n      \"deliverables\": \"69\",\n      \"icon\": \"5w\"\n    },\n    \"cross-platform\",\n    \"Cross-Platform Mobile\",\n    \"One codebase for iOS and Android\",\n    \"React Native or Flutter apps that share logic and UI across iOS and Android. We optimize for performance and native feel.\",\n    \"Platform strategy\",\n    \"Shared codebase development\",\n    \"Platform-specific polish\",\n    \"Release to both stores\",\n    [\n      \"6f\",\n      \"6g\",\n      \"6h\",\n      \"6i\"\n    ],\n    \"iOS + Android app\",\n    \"Shared component library\",\n    \"Store listings\",\n    \"Single codebase docs\",\n    [\n      \"6k\",\n      \"6l\",\n      \"6m\",\n      \"6n\"\n    ],\n    {\n      \"id\": \"6b\",\n      \"slug\": \"6b\",\n      \"name\": \"6c\",\n      \"shortDescription\": \"6d\",\n      \"description\": \"6e\",\n      \"process\": \"6j\",\n      \"deliverables\": \"6o\",\n      \"icon\": \"6b\"\n    },\n    \"ui-ux\",\n    \"UI/UX Design\",\n    \"User-centered design and prototyping\",\n    \"Research, wireframes, and high-fidelity designs. We create interfaces that are accessible, consistent, and aligned with your brand.\",\n    \"User research\",\n    \"Wireframes & flows\",\n    \"Visual design\",\n    \"Prototypes & handoff\",\n    [\n      \"6u\",\n      \"6v\",\n      \"6w\",\n      \"6x\"\n    ],\n    \"Design system\",\n    \"Figma/Sketch files\",\n    \"Prototypes\",\n    \"Specs for development\",\n    [\n      \"6z\",\n      \"70\",\n      \"71\",\n      \"72\"\n    ],\n    {\n      \"id\": \"6q\",\n      \"slug\": \"6q\",\n      \"name\": \"6r\",\n      \"shortDescription\": \"6s\",\n      \"description\": \"6t\",\n      \"process\": \"6y\",\n      \"deliverables\": \"73\",\n      \"icon\": \"6q\"\n    },\n    \"api-backend\",\n    \"API & Backend\",\n    \"APIs, backends, and DevOps\",\n    \"REST and GraphQL APIs, microservices, and cloud infrastructure. We use Laravel, Node, or Go depending on your needs.\",\n    \"API design\",\n    \"Implementation & tests\",\n    \"Documentation\",\n    \"Deploy & monitor\",\n    [\n      \"79\",\n      \"7a\",\n      \"7b\",\n      \"7c\"\n    ],\n    \"API + docs\",\n    \"Database design\",\n    \"CI/CD\",\n    \"Monitoring setup\",\n    [\n      \"7e\",\n      \"7f\",\n      \"7g\",\n      \"7h\"\n    ],\n    \"api\",\n    {\n      \"id\": \"75\",\n      \"slug\": \"75\",\n      \"name\": \"76\",\n      \"shortDescription\": \"77\",\n      \"description\": \"78\",\n      \"process\": \"7d\",\n      \"deliverables\": \"7i\",\n      \"icon\": \"7j\"\n    },\n    [\n      \"5g\",\n      \"5v\",\n      \"6a\",\n      \"6p\",\n      \"74\",\n      \"7k\"\n    ],\n    \"starter\",\n    \"Starter\",\n    \"From $5,000\",\n    \"project\",\n    \"Ideal for MVPs and small projects.\",\n    \"Up to 3 core features\",\n    \"Design + development\",\n    \"2 revision rounds\",\n    \"30-day support\",\n    [\n      \"7r\",\n      \"7s\",\n      \"7t\",\n      \"7u\"\n    ],\n    \"Get started\",\n    {\n      \"id\": \"7m\",\n      \"name\": \"7n\",\n      \"price\": \"7o\",\n      \"period\": \"7p\",\n      \"description\": \"7q\",\n      \"features\": \"7v\",\n      \"cta\": \"7w\",\n      \"highlighted\": \"2l\"\n    },\n    \"growth\",\n    \"Growth\",\n    \"From $15,000\",\n    \"Full product build with ongoing support.\",\n    \"Full scope development\",\n    \"Dedicated project manager\",\n    \"Unlimited revisions\",\n    \"3 months support\",\n    \"Analytics & SEO\",\n    [\n      \"82\",\n      \"83\",\n      \"84\",\n      \"85\",\n      \"86\"\n    ],\n    \"Contact us\",\n    {\n      \"id\": \"7y\",\n      \"name\": \"7z\",\n      \"price\": \"80\",\n      \"period\": \"7p\",\n      \"description\": \"81\",\n      \"features\": \"87\",\n      \"cta\": \"88\",\n      \"highlighted\": \"20\"\n    },\n    \"enterprise\",\n    \"Enterprise\",\n    \"Custom\",\n    \"Large-scale and long-term partnerships.\",\n    \"Custom scope\",\n    \"Dedicated team\",\n    \"SLA & security review\",\n    \"Ongoing maintenance\",\n    \"Priority support\",\n    [\n      \"8e\",\n      \"8f\",\n      \"8g\",\n      \"8h\",\n      \"8i\"\n    ],\n    \"Request quote\",\n    {\n      \"id\": \"8a\",\n      \"name\": \"8b\",\n      \"price\": \"8c\",\n      \"period\": \"4f\",\n      \"description\": \"8d\",\n      \"features\": \"8j\",\n      \"cta\": \"8k\",\n      \"highlighted\": \"2l\"\n    },\n    [\n      \"7x\",\n      \"89\",\n      \"8l\"\n    ],\n    \"How long does a typical project take?\",\n    \"Small projects (MVP, landing page) often take 4–8 weeks. Full web or mobile apps usually 3–6 months depending on scope. We provide a timeline after discovery.\",\n    {\n      \"question\": \"8n\",\n      \"answer\": \"8o\"\n    },\n    \"Do you work with startups?\",\n    \"Yes. We work with startups at all stages and can align with equity, milestones, or phased payments where it makes sense.\",\n    {\n      \"question\": \"8q\",\n      \"answer\": \"8r\"\n    },\n    \"What tech stack do you use?\",\n    \"We choose the stack per project: Laravel, Node, or Go for backend; React, Vue, or Qwik for web; Swift/Kotlin for native; React Native or Flutter for cross-platform. We recommend based on your goals and team.\",\n    {\n      \"question\": \"8t\",\n      \"answer\": \"8u\"\n    },\n    \"Do you offer ongoing support?\",\n    \"Yes. We offer maintenance plans (bug fixes, updates, monitoring) and can scale to ongoing feature work or dedicated capacity.\",\n    {\n      \"question\": \"8w\",\n      \"answer\": \"8x\"\n    },\n    \"Can you take over an existing project?\",\n    \"Yes. We do audits and handoffs: we review codebase, docs, and infra, then propose a plan for fixes, refactors, or new features.\",\n    {\n      \"question\": \"8z\",\n      \"answer\": \"90\"\n    },\n    [\n      \"8p\",\n      \"8s\",\n      \"8v\",\n      \"8y\",\n      \"91\"\n    ],\n    \"hello@credocode.com\",\n    \"+1 (555) 123-4567\",\n    \"123 Agency Street, Suite 100, City, ST 12345\",\n    \"https://calendly.com/credocode\",\n    \"LinkedIn\",\n    \"https://linkedin.com/company/credocode\",\n    \"linkedin\",\n    {\n      \"name\": \"97\",\n      \"url\": \"98\",\n      \"icon\": \"99\"\n    },\n    \"Twitter\",\n    \"https://twitter.com/credocode\",\n    \"twitter\",\n    {\n      \"name\": \"9b\",\n      \"url\": \"9c\",\n      \"icon\": \"9d\"\n    },\n    \"GitHub\",\n    \"https://github.com/credocode\",\n    \"github\",\n    {\n      \"name\": \"9f\",\n      \"url\": \"9g\",\n      \"icon\": \"9h\"\n    },\n    [\n      \"9a\",\n      \"9e\",\n      \"9i\"\n    ],\n    {\n      \"email\": \"93\",\n      \"phone\": \"94\",\n      \"address\": \"95\",\n      \"calendarLink\": \"96\",\n      \"socials\": \"9j\"\n    },\n    \"React\",\n    \"Vue\",\n    \"Qwik\",\n    \"Flutter\",\n    \"PostgreSQL\",\n    \"Redis\",\n    \"AWS\",\n    \"Docker\",\n    [\n      \"3r\",\n      \"3b\",\n      \"9l\",\n      \"9m\",\n      \"9n\",\n      \"3a\",\n      \"9o\",\n      \"44\",\n      \"45\",\n      \"9p\",\n      \"9q\",\n      \"9r\",\n      \"9s\"\n    ],\n    \"We build digital products that scale.\",\n    \"To partner with ambitious teams and deliver web and mobile solutions that are fast, reliable, and a pleasure to use.\",\n    \"Quality over speed\",\n    \"Clear communication\",\n    \"Long-term partnerships\",\n    \"Inclusive and accessible design\",\n    [\n      \"9w\",\n      \"9x\",\n      \"9y\",\n      \"9z\"\n    ],\n    \"Alex Johnson\",\n    \"Lead Developer\",\n    \"Full-stack with a focus on performance and APIs.\",\n    {\n      \"name\": \"a1\",\n      \"role\": \"a2\",\n      \"bio\": \"a3\"\n    },\n    \"Sam Williams\",\n    \"Design Lead\",\n    \"UI/UX and design systems.\",\n    {\n      \"name\": \"a5\",\n      \"role\": \"a6\",\n      \"bio\": \"a7\"\n    },\n    \"Jordan Lee\",\n    \"Mobile Lead\",\n    \"Native iOS and Android, and cross-platform.\",\n    {\n      \"name\": \"a9\",\n      \"role\": \"aa\",\n      \"bio\": \"ab\"\n    },\n    [\n      \"a4\",\n      \"a8\",\n      \"ac\"\n    ],\n    \"Discovery\",\n    \"We align on goals, scope, and success metrics.\",\n    {\n      \"title\": \"ae\",\n      \"description\": \"af\"\n    },\n    \"Design\",\n    \"Wireframes, visual design, and prototypes.\",\n    {\n      \"title\": \"ah\",\n      \"description\": \"ai\"\n    },\n    \"Build\",\n    \"Iterative development with regular demos.\",\n    {\n      \"title\": \"ak\",\n      \"description\": \"al\"\n    },\n    \"Launch\",\n    \"Deploy, monitor, and hand off with docs and support.\",\n    {\n      \"title\": \"an\",\n      \"description\": \"ao\"\n    },\n    [\n      \"ag\",\n      \"aj\",\n      \"am\",\n      \"ap\"\n    ],\n    50,\n    \"Projects delivered\",\n    {\n      \"value\": \"ar\",\n      \"label\": \"as\"\n    },\n    8,\n    \"Years experience\",\n    {\n      \"value\": \"au\",\n      \"label\": \"av\"\n    },\n    99,\n    \"Client satisfaction %\",\n    {\n      \"value\": \"ax\",\n      \"label\": \"ay\"\n    },\n    [\n      \"at\",\n      \"aw\",\n      \"az\"\n    ],\n    {\n      \"tagline\": \"9u\",\n      \"mission\": \"9v\",\n      \"values\": \"a0\",\n      \"team\": \"ad\",\n      \"processTimeline\": \"aq\",\n      \"stats\": \"b0\"\n    },\n    {\n      \"services\": \"7l\",\n      \"pricingTiers\": \"8m\",\n      \"faq\": \"92\",\n      \"contact\": \"9k\",\n      \"techStack\": \"9t\",\n      \"about\": \"b1\"\n    },\n    \"building-fast-websites-with-qwik\",\n    \"Building Fast Websites with Qwik\",\n    \"Why we chose Qwik for our marketing site and how resumability improves performance.\",\n    \"2025-01-15\",\n    {\n      \"name\": \"a1\"\n    },\n    \"<p>Modern frameworks often ship too much JavaScript. Qwik takes a different approach: resumability. The server sends HTML and only the minimal JS needed for interactivity is loaded when the user needs it.</p><p>For a marketing site, that means faster First Contentful Paint and Time to Interactive, especially on mobile. We use Qwik City for routing and server-side rendering, and Tailwind for styling.</p><p>If you're considering a new frontend, give Qwik a look for content-heavy or marketing sites where every kilobyte counts.</p>\",\n    {\n      \"id\": \"33\",\n      \"slug\": \"b3\",\n      \"title\": \"b4\",\n      \"excerpt\": \"b5\",\n      \"date\": \"b6\",\n      \"author\": \"b7\",\n      \"body\": \"b8\"\n    },\n    \"api-design-best-practices\",\n    \"API Design Best Practices for Mobile and Web\",\n    \"REST and versioning, auth, and how to keep your API maintainable as you scale.\",\n    \"2025-01-08\",\n    {\n      \"name\": \"a9\"\n    },\n    \"<p>A well-designed API makes both web and mobile clients easier to build and maintain. We recommend REST with clear resource naming, consistent status codes, and versioning in the URL path.</p><p>Use JSON for request and response bodies, and document everything with OpenAPI or similar. For auth, prefer tokens (e.g. Laravel Sanctum) with short expiry and refresh flows.</p><p>Finally, add rate limiting and CORS from day one so you don't have to retrofit later.</p>\",\n    {\n      \"id\": \"3j\",\n      \"slug\": \"ba\",\n      \"title\": \"bb\",\n      \"excerpt\": \"bc\",\n      \"date\": \"bd\",\n      \"author\": \"be\",\n      \"body\": \"bf\"\n    },\n    \"why-we-use-laravel-for-backends\",\n    \"Why We Use Laravel for Backends\",\n    \"Laravel remains our go-to for APIs and admin tools. Here's why.\",\n    \"2025-01-01\",\n    {\n      \"name\": \"a1\"\n    },\n    \"<p>Laravel gives us a solid foundation: routing, validation, Eloquent ORM, queues, and a strong ecosystem. For agency work, that means we spend less time on boilerplate and more on business logic.</p><p>Laravel Sanctum makes SPA and mobile auth straightforward. When we need to ship an API plus an admin dashboard, Laravel lets us do both in one codebase with clear separation.</p><p>We still pick Node or Go when the problem fits better, but for most CRUD-heavy products, Laravel is our default.</p>\",\n    {\n      \"id\": \"4l\",\n      \"slug\": \"bh\",\n      \"title\": \"bi\",\n      \"excerpt\": \"bj\",\n      \"date\": \"bk\",\n      \"author\": \"bl\",\n      \"body\": \"bm\"\n    },\n    [\n      \"b9\",\n      \"bg\",\n      \"bn\"\n    ],\n    {\n      \"caseStudies\": \"4b\",\n      \"testimonials\": \"51\",\n      \"siteContent\": \"b2\",\n      \"blogPosts\": \"bo\"\n    },\n    \"\\u0013g! zx09sF00p7Y\",\n    \"\\u0002/node_modules/@builder.io/qwik-city/lib/index.qwik.mjs_QwikCityProvider_component_registerPreventNav_2t6mPTtqQ2E.js#QwikCityProvider_component_registerPreventNav_2t6mPTtqQ2E\",\n    \"\\u0011bq @5\",\n    \"What our clients say\",\n    \"Trusted by startups and enterprises.\",\n    {\n      \"$$testimonials\": \"bs\",\n      \"title\": \"bt\",\n      \"subtitle\": \"bu\"\n    },\n    \"\\u0002/src/components/marketing/TestimonialGrid.tsx_TestimonialGrid_component_ebV06fOogH8.js#TestimonialGrid_component_ebV06fOogH8\",\n    {},\n    {},\n    \"initial\",\n    {\n      \"type\": \"bz\",\n      \"dest\": \"2j\"\n    },\n    \"\\u0002/node_modules/@builder.io/qwik-city/lib/index.qwik.mjs_QwikCityProvider_component_useTask_PUQDlhoAX70.js#QwikCityProvider_component_useTask_PUQDlhoAX70[j 3! h f! kp c3 g! bx by! i 2!]\",\n    \"\\u00032 g c1 #1\",\n    \"\\u0002/node_modules/@builder.io/qwik-city/lib/index.qwik.mjs_QwikCityProvider_component_goto_D04JSRMJKKg.js#QwikCityProvider_component_goto_D04JSRMJKKg[j bx i 2!]\",\n    \"\\u0012#i\",\n    \"\\u0002/node_modules/@builder.io/qwik-city/lib/index.qwik.mjs_Link_component_handlePrefetch_0Mors0d0PQ0.js#Link_component_handlePrefetch_0Mors0d0PQ0\",\n    \"/\",\n    \"text-xl font-bold text-slate-900 dark:text-white\",\n    \"Home\",\n    {\n      \"href\": \"c6\",\n      \"class\": \"c7\",\n      \"aria-label\": \"c8\"\n    },\n    \"\\u0002/node_modules/@builder.io/qwik-city/lib/index.qwik.mjs_Link_component_useVisibleTask_ifypNASzol4.js#Link_component_useVisibleTask_ifypNASzol4[c4 c5 c9 2!]\",\n    \"\\u00031 3 ca #h\",\n    \"\\u0012#k\",\n    \"\\u0002/node_modules/@builder.io/qwik-city/lib/index.qwik.mjs_Link_compone