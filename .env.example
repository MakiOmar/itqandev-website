# --- Laravel API (required for marketing API + dashboard auth) ---
# Dev (recommended): relative /api + Vite proxy so SSR and browser share the same origin.
# Point VITE_API_PROXY_TARGET at your Laravel `public` folder (WAMP vhost or subdirectory).
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://itqandev.com/credocode/backend/public
# When Vite picks another port (e.g. 5174), set this so Node SSR uses the same origin:
# VITE_DEV_SERVER_ORIGIN=http://127.0.0.1:5174

# Production or direct SSR (no Vite proxy): full API root including /api
# VITE_API_BASE_URL=https://your-domain.com/api
# Optional when Node SSR must bypass the dev proxy:
# VITE_SSR_API_BASE_URL=http://itqandev.com/credocode/backend/public/api

# Optional explicit marketing API (defaults to VITE_API_BASE_URL)
# VITE_MARKETING_API_URL=/api

# Public site canonical URL (SEO canonical + optional Sanctum SSR header override when `www` ≠ apex)
# VITE_SITE_URL=http://localhost

# --- Auth (see website/docs/CONFIGURATION.md) ---
# Production: always use Laravel (mock is for offline UI demos only).
VITE_AUTH_PROVIDER=laravel
# VITE_LARAVEL_SANCTUM=true
# VITE_PUBLIC_LOGIN=/admin/login

# --- Marketing content (local JSON vs Laravel public API) ---
# VITE_MARKETING_CONTENT_SOURCE=api
